@article{ThereminAsLearningTool,
    author = {Alonso-Pérez, Silvia},
    title = {Use of a Theremin as an Introductory Physics and Electronics Learning Tool},
    journal = {The Physics Teacher},
    volume = {61},
    number = {9},
    pages = {742-745},
    year = {2023},
    month = {12},
    abstract = {Previous authors have described the use of this instrument in teaching a variety of subjects, such as geometry,5 electromagnetism,6 undulatory physics,7 electronics and signal processing,8,9 musical expression for people with complex learning needs,10 and the link between physics and music.11The fact that the theremin is played without physical contact of the musician with the instrument is of great interest for using it as an active learning tool in the post-2020 era. The COVID-19 crisis has shown us the necessity of redefining some learning activities, especially those involving practical skills.12 With the use of a theremin, the students can be actively involved in an engaging learning activity with more sanitary guarantees.},
    issn = {0031-921X},
    doi = {10.1119/5.0095524},
    url = {https://doi.org/10.1119/5.0095524},
    eprint = {https://pubs.aip.org/aapt/pte/article-pdf/61/9/742/20132635/742_1_5.0095524.pdf},
}

